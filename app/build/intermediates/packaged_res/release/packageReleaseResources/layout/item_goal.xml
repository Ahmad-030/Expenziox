<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@color/colorCard"
    app:strokeColor="@color/colorCardStroke"
    app:strokeWidth="1dp">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="18dp">

        <!-- Header -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <TextView android:id="@+id/tvGoalName"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Emergency Fund"
                android:textSize="16sp" android:textStyle="bold"
                android:textColor="@color/colorTextPrimary" />

            <TextView android:id="@+id/tvPriority"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="High"
                android:textSize="11sp" android:textStyle="bold"
                android:background="@drawable/priority_badge_bg"
                android:paddingStart="10dp" android:paddingEnd="10dp"
                android:paddingTop="4dp" android:paddingBottom="4dp" />
        </LinearLayout>

        <!-- Progress row -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="0dp" android:layout_height="8dp"
                android:layout_weight="1"
                android:layout_marginEnd="12dp"
                style="@android:style/Widget.ProgressBar.Horizontal"
                android:progressDrawable="@android:drawable/progress_horizontal"
                android:max="100" android:progress="0" />

            <TextView android:id="@+id/tvProgress"
                android:layout_width="40dp" android:layout_height="wrap_content"
                android:text="0%"
                android:textSize="13sp" android:textStyle="bold"
                android:textColor="@color/colorTeal"
                android:gravity="end" />
        </LinearLayout>

        <!-- Saved / Target -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <TextView android:id="@+id/tvSaved"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="PKR 0 / PKR 0"
                android:textSize="13sp" android:textColor="@color/colorTextSecondary" />

            <TextView android:id="@+id/tvDeadline"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="🗓 2025-12-31"
                android:textSize="12sp" android:textColor="@color/colorTextSecondary" />
        </LinearLayout>

        <!-- Add savings button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAddSavings"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:text="+ Add Savings"
            android:textSize="13sp"
            android:textColor="@color/colorTeal"
            app:strokeColor="@color/colorTeal"
            app:strokeWidth="1dp"
            app:cornerRadius="12dp" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
