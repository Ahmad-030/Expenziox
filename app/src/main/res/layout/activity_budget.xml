<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/colorBackground">

    <ScrollView android:id="@+id/budgetScrollContainer"
        android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="20dp">

            <!-- Info tip -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="16dp" app:cardElevation="0dp"
                app:cardBackgroundColor="#0D00D4AA"
                app:strokeColor="#1A00D4AA" app:strokeWidth="1dp"
                xmlns:app="http://schemas.android.com/apk/res-auto">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:padding="16dp"
                    android:gravity="center_vertical">

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="💡" android:textSize="20sp" android:layout_marginEnd="12dp" />

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Set a monthly spending limit per category. The bar turns red when you exceed it."
                        android:textSize="12sp" android:textColor="@color/colorTeal"
                        android:lineSpacingMultiplier="1.4" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout android:id="@+id/budgetContainer"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" />

        </LinearLayout>
    </ScrollView>

    <include layout="@layout/bottom_nav" />
</LinearLayout>